Процедура название_БокировкаПользователейЗУПБитрикс() Экспорт
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    | КадроваяИсторияСотрудников.ФизическоеЛицо КАК ФизическоеЛицо,
    | КадроваяИсторияСотрудников.Сотрудник.Код КАК СотрудникКод
    |ИЗ РегистрСведений.КадроваяИсторияСотрудников
    |ГДЕ ВидСобытия = &ВидСобытия И Период МЕЖДУ &НачалоПериода И &КонецПериода";
    НачалоПериода = НачалоДня(ТекущаяДата());
    КонецПериода = КонецДня(ТекущаяДата());
    Запрос.УстановитьПараметр("ВидСобытия", Перечисле-ния.ВидыКадровыхСобытий.Увольнение);
    Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
    Запрос.УстановитьПараметр("КонецПериода", КонецПериода);

    РезультатЗапроса = Запрос.Выполнить();
    ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

    Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
        // Блокировка учётной записи в 1С
        ПользовательСсылка = Справочни-ки.Пользователи.НайтиПоРеквизиту("ФизическоеЛицо", ВыборкаДетальныеЗапи-си.ФизическоеЛицо);
        Если ПользовательСсылка <> Справочни-ки.Пользователи.ПустаяСсылка() Тогда
            ПользовательОбъект = ПользовательСсылка.ПолучитьОбъект();
            ПользовательОбъект.Недействителен = Истина;
            ПользовательОбъект.Записать();
        КонецЕсли;

        // Блокировка в Битрикс24 через REST API
        Соединение = Новый HTTPСоединение(АдресПортала, , , , , , Новый ЗащищенноеСоединениеOpenSSL);
        Запрос = Новый HTTPЗапрос(ВебхукПолучение + ВыборкаДетальныеЗа-писи.СотрудникКод);
        Запрос.УстановитьТелоИзСтроки("");
        Ответ = Соединение.ОтправитьДляОбработки(Запрос);
        СтрокаОтвета = Ответ.ПолучитьТелоКакСтроку();
        ЧтениеJSON = Новый ЧтениеJSON;
        ЧтениеJSON.УстановитьСтроку(СтрокаОтвета);
        СтрокаОтвета = ПрочитатьJSON(ЧтениеJSON);

        Если СтрокаОтвета.result.Количество() = 1 Тогда
            Запрос = Новый HTTPЗапрос(ВебхукИзменение + "?ID=" + Стро-каОтвета.result[0].ID + "&ACTIVE=N");
            Запрос.УстановитьТелоИзСтроки("");
            Соединение.ОтправитьДляОбработки(Запрос);
        КонецЕсли;
    КонецЦикла;
