&НаКлиенте
Процедура КомандаЗагрузитьИзФайла(Команда)
    // Авторизация и получение токена (реальный код из вашей обработки)
    АдресПортала = "название";
    Соединение = Новый HTTPСоединение(АдресПортала, номер, , , , , Новый ЗащищенноеСоединениеOpenSSL);
    Данные = Новый Структура("название, название", "название", "назва-ние");
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    СтрокаJSON = ЗаписьJSON.Закрыть();
    Запрос = Новый HTTPЗапрос(Ресурс, Заголовки);
    Запрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
    Ответ1 = Соединение.ВызватьHTTPМетод("POST", Запрос);
    Ответ1Строка = Ответ1.ПолучитьТелоКакСтроку();
    Если Ответ1.КодСостояния = 200 Тогда
        ОтветДанные = ПолучитьДанныеИзJson(Ответ1Строка);
        Токен = ОтветДанные.accessToken;
        СохранитьТокен(Токен);
    КонецЕсли;

    // Запрос топливных операций
    Заголовки.Вставить("название", "название " + Токен);
    Ресурс = "название";
    ПараметрыЗапроса = "?companyId=" + Строка(IdКомпании) + "&dateFrom=" + Формат(Объект.ПериодЗагрузки.ДатаНачала,"ДФ=дд.ММ.гггг") + "&dateTo=" + Фор-мат(КонецДня(Объект.ПериодЗагрузки.ДатаОкончания),"ДФ=дд.ММ.гггг hh:mm:ss");
    Запрос = Новый HTTPЗапрос(Ресурс+ПараметрыЗапроса, Заголовки);
    Ответ3 = Соединение.ВызватьHTTPМетод("GET", Запрос);
    ДанныеЗаправки = Ответ3.ПолучитьТелоКакСтроку();
    ДанныеДляЗагрузки = ПолучитьДанныеИзJson(ДанныеЗаправки);
    ЗагрузитьДанные(ДанныеДляЗагрузки);
    ЗаполнитьНедостающиеРеквизиты();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанные(мДанные)
    Данные = мДанные.listDatas;
    Для каждого Стр из Данные Цикл
        НовСтрока = Объект.ДанныеДляОбработки.Добавить();
        НовСтрока.НомерТопливнойКарты = Стр.user.rfidKey;
        ДатаДень = Число(Сред(Стр.date, 9,2));
        ДатаМесяц = Число(Сред(Стр.date,6,2));
        ДатаГод = Число(Лев(Стр.date,4));
        НовСтрока.ДатаЗаправки = Дата(ДатаГод, ДатаМесяц, ДатаДень);
        НовСтрока.ВидТоплива = Стр.fuel.name;
        НовСтрока.Количество = Стр.countLitre;
        НовСтрока.ПользовательТопливнойКарты = Стр.user.firstName;
    КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНедостающиеРеквизиты()
    Для каждого мСтрока из Объект.ДанныеДляОбработки Цикл
        // Поиск топливной карты
        мТопливнаяКарта = ОпределитьТопливнуюКартуПоКо-ду(мСтрока.НомерТопливнойКарты, мСтрока.ДатаЗаправки);
        Если ЗначениеЗаполнено(мТопливнаяКарта) Тогда
            Если ТипЗнч(мТопливнаяКарта.КомуВыдана) = Тип("СправочникСсылка.ТранспортныеСредства") Тогда
                мСтрока.ТранспортноеСредство = мТопливнаяКар-та.КомуВыдана;
            Иначе
                // получение подразделения водителя
                РеквизитыФизЛица = уатОбщегоНазначе-ния.уатПрочитатьРеквизитыВодителя(мТопливнаяКарта.КомуВыдана, мСтро-ка.ДатаЗаправки,);
                мСтрока.Подразделение = РеквизитыФизЛи-ца.ПодразделениеОрганизации;
            КонецЕсли;
        КонецЕсли;
        // Поиск склада по подразделению
        ПоискСклад = Объ-ект.СоответствиеПодразделенийСкладов.НайтиСтроки(Новый Структу-ра("Подразделение", мСтрока.Подразделение));
        Если ПоискСклад.Количество() > 0 Тогда
            мСтрока.название = ПоискСклад[0].название;
        КонецЕсли;
        // Сопоставление вида топлива
        Если мСтрока.ВидТоплива = "ДТ" Тогда
            мСтрока.название = Справочни-ки.Номенклатура.НайтиПоНаименованию("название");
        ИначеЕсли мСтрока.ВидТоплива = "АИ-92" Тогда
            мСтрока.название = Справочни-ки.Номенклатура.НайтиПоНаименованию("БЕНЗИН АИ-92");
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура СоздатьЗаправкиНаСервере()
    // Создание документа заправки
    Для каждого Зап из ТабЗаправка Цикл
        Док = Документы.название.СоздатьДокумент();
        Док.Организация = Объект.Организация;
        Док.Дата = Зап.ДатаДень;
        Док.Ответственный = ПараметрыСеанса.ТекущийПользователь;
        Док.Записать(РежимЗаписиДокумента.Запись, РежимПроведенияДоку-мента.Неоперативный);
        Для каждого Стр из ТабТЧ Цикл
            ДокЗаправки = Док.Заправки.Добавить();
            ДокЗаправки.ТС = Стр.ТранспортноеСредство;
            ДокЗаправки.название = Стр.название;
            ДокЗаправки.Количество = Стр.Количество;
        КонецЦикла;
        Попытка
            Док.Записать(РежимЗаписиДокумента.Проведение, РежимПроведе-нияДокумента.Неоперативный);
        Исключение
            ОписаниеОшибки = ОписаниеОшибки();
            Сообщение = Новый СообщениеПользователю;
            Сообщение.Текст = ОписаниеОшибки;
            Сообщение.Сообщить();
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры
