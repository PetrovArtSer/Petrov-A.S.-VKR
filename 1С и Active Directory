&НаСервере
Процедура СоздатьУчетныеЗаписи(АДОКоннектор, ВТ_Принятые, ФайлПротокола)

    objRootLDAP = ПолучитьCOMОбъект("LDAP://rootDSE");
    strDC = objRootLDAP.Get("defaultNamingContext");
    ИмяГруппыAD = "OU=ZUP,OU=test.com,";
    strOU = ИмяГруппыAD;
    objContainer = ПолучитьCOMОбъект("LDAP://" + strOU + strDC);

    Для каждого СтрокаВТ из ВТ_Принятые Цикл
        cn_name = СОКРЛП(СтрокаВТ.ФизическоеЛицо.Наименование);
        Попытка
            objUser = objContainer.Create("User","cn=" + cn_name);
            objUser.SetInfo();

            // Заполнение атрибутов
            парам = новый Структура;
            парам.Вставить("employeeID", СтрокаВТ.ТабельныйНомер);
            парам.Вставить("company", Стро-каВТ.Организация.Наименование);
            парам.Вставить("department", Стро-каВТ.Подразделение.Наименование);
            парам.Вставить("title", СтрокаВТ.Должность.Наименование);
            парам.Вставить("displayName", cn_name);
            ЗаполнитьЗначенияСвойств(objUser, парам, "employeeID, com-pany, department, title, displayName");
            objUser.SetInfo();

            // Настройка учётной записи
            objUser.pwdLastSet = 0;
            objUser.userPrincipalName = ИмяТранслитер + "@" + strDomain;
            objUser.sAMAccountName = ИмяТранслитер;
            objUser.Comment = "Создан обменом из ЗУП " + Стро-ка(ТекущаяДата());
            objUser.SetInfo();
        Исключение
            // обработка ошибки
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры

Процедура ОбновитьУчетныеЗаписи(АДОКоннектор, ВТ_Перемещенные, ФайлПро-токола, ТипИзменения)
    Для каждого СтрокаВТ из ВТ_Перемещенные Цикл
        query = "SELECT AdsPath FROM 'LDAP://test.com' WHERE employeeID = '" + СтрокаВТ.ТабельныйНомер + "'";
        Попытка
            rs = АДОКоннектор.Execute(query);
            Если НЕ rs.EOF() тогда
                ПутьОбъекта = rs.Fields("AdsPath").Value;
                ОбъектАД = ПолучитьCOMОбъект(ПутьОбъекта);
                // обновление атрибутов
                ОбъектАД.department = Стро-каВТ.Подразделение.Наименование;
                ОбъектАД.title = СтрокаВТ.Должность.Наименование;
                ОбъектАД.SetInfo();
            КонецЕсли;
        Исключение
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры

Процедура ОтключитьУчетныеЗаписи(АДОКоннектор, ВТ_Уволенные, ФайлПрото-кола)
    Для каждого СтрокаВТ из ВТ_Уволенные Цикл
        query = "SELECT AdsPath FROM 'LDAP://test.com' WHERE employeeID = '" + СтрокаВТ.ТабельныйНомер + "'";
        Попытка
            rs = АДОКоннектор.Execute(query);
            Если НЕ rs.EOF() тогда
                ПутьОбъекта = rs.Fields("AdsPath").Value;
                ОбъектАД = ПолучитьCOMОбъект(ПутьОбъекта);
                ОбъектАД.AccountDisabled = Истина;
                ОбъектАД.Comment = "Заблокирован обменом из ЗУП " + Строка(ТекущаяДата());
                ОбъектАД.SetInfo();
            КонецЕсли;
        Исключение
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры
